{
  "manifest_version": 3,
  "name": "Download Product Images",
  "version": "1.0",
  "description": "Download Product Images",
  "action": {
    "default_icon": "icon.png",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "downloads",
    "clipboardWrite"
  ]
}
