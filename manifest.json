{
  "manifest_version": 2,
  "name": "Download 1688 Images",
  "version": "1.0",
  "description": "Download 1688 Images",
  "browser_action": {
    "default_icon": "icon.png",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": [
    "activeTab",
    "downloads"
  ]
}
